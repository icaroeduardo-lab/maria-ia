generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Flow {
  id        String        @id @default(cuid())
  name      String
  nodes     Json          @default("[]") // array de FlowNode
  edges     Json          @default("[]") // array de FlowEdge
  active    Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  versions  FlowVersion[]
}

// Snapshot do fluxo a cada save (PUT) — permite histórico e rollback no painel.
model FlowVersion {
  id       String   @id @default(cuid())
  flowId   String
  flow     Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  versao   Int // sequencial por flow (1, 2, 3...)
  name     String
  nodes    Json     @default("[]")
  edges    Json     @default("[]")
  autor    String? // email de quem salvou (do JWT)
  criadoEm DateTime @default(now())

  @@unique([flowId, versao])
  @@index([flowId, criadoEm])
}

// Contagem de passagens por nó, por fluxo — funil/drop-off (card #20260119).
// Incrementado a cada execução real do node (não é histórico, só contador
// acumulado); usado por GET /admin/analytics/funil/{flowId}.
model NodeVisita {
  id        String   @id @default(cuid())
  flowId    String
  nodeId    String
  total     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([flowId, nodeId])
  @@index([flowId])
}

// Fila de retry de envios à DPERJ que falharam (antes em SQLite local efêmero).
model DperjFila {
  id         String   @id @default(cuid())
  payload    Json
  tentativas Int      @default(0)
  ultimoErro String?
  criadoEm   DateTime @default(now())

  @@index([criadoEm])
}

model Conversation {
  id             String    @id @default(cuid())
  sessionId      String    @unique
  channel        String // "whatsapp" | "web"
  flowId         String? // null = grafo estático
  status         String    @default("active") // "active" | "completed" | "abandoned"
  categoria      String?
  ultimaEtapa    String? // último node executado (análise de abandono)
  dadosColetados Json      @default("{}")
  resumo         String?   // resumo do caso (gerado no fim do atendimento)
  metadados      Json?     // metadados limpos: identidade + caso + encaminhamento
  protocoloDperj String?
  startedAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  // Handoff pra atendente humano (nó transferir_humano) — null = fluxo normal.
  // "aguardando" = bot pausado, ninguém assumiu ainda; "em_atendimento" = um
  // operador assumiu e responde diretamente; liberar volta a null.
  handoffStatus   String? // "aguardando" | "em_atendimento"
  handoffOperador String? // email/nome do operador que assumiu
  handoffDesde    DateTime?

  @@index([startedAt])
  @@index([handoffStatus])
}

model User {
  id    String @id @default(cuid())
  email String @unique
  senha String // hash bcrypt
  nome  String @default("")
  role  String @default("viewer") // "admin" | "viewer"
}

// Auditoria de acesso a dados sensíveis (quem revelou PII, quando)
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  acao      String // "revelar"
  alvoTipo  String // "assistido" | "conversa"
  alvoId    String
  criadoEm  DateTime @default(now())

  @@index([criadoEm])
}

// Configuração global (singleton id="default"): preâmbulo de estilo aplicado
// a toda geração de texto da IA (linguagem simples, tom da Defensoria).
model Config {
  id            String   @id @default("default")
  estiloPrompt  String   @default("")
  conversacional Boolean @default(true) // IA reescreve perguntas de forma acolhedora
  updatedAt     DateTime @updatedAt
}

// Assistido = cidadão atendido (≠ User, que é o operador do painel).
// O fluxo consulta por CPF, cadastra quem não existe e atualiza dados.
model Assistido {
  id             String   @id @default(cuid())
  cpf            String   @unique // somente dígitos (11)
  nome           String
  dataNascimento String?
  nomeMae        String?
  situacao       String   @default("regular")
  municipio      String?
  uf             String?
  telefone       String?
  email          String?
  cep            String?
  bairro         String?
  logradouro     String?
  numero         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  casos          Caso[]
}

// Caso jurídico do assistido (processo/atendimento). Usado para identificar
// casos em aberto na entrada do fluxo.
model Caso {
  id            String    @id @default(cuid())
  identificador String // número/código visível ao assistido (ex: "0801234-56.2025")
  tipo          String // "Pensão alimentícia", "Divórcio", ...
  status        String    @default("aberto") // "aberto" | "encerrado"
  assistidoId   String
  assistido     Assistido @relation(fields: [assistidoId], references: [id], onDelete: Cascade)
  criadoEm      DateTime  @default(now())

  @@index([assistidoId, status])
}
