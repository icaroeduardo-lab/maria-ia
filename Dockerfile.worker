# Serviço worker: consome a fila SQS e processa as mensagens (LangGraph).
# A mesma imagem roda os jobs agendados (EventBridge sobrescreve o comando:
# node dist/jobs.js <retry-dperj|limpeza|health>).
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@latest --activate
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

FROM base AS build
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN pnpm build   # prisma generate + tsc

FROM base AS runner
ENV NODE_ENV=production
# fontes p/ render da ficha (o worker pode gerar imagem via sharp no fluxo)
RUN apk add --no-cache fontconfig ttf-dejavu && fc-cache -f
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/dist ./dist
COPY --from=build /app/prisma ./prisma
COPY package.json ./
# não roda migração (a api é dona disso); só consome a fila
CMD ["pnpm", "start:worker"]
