generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String  @id @default(cuid())
  slug               String  @unique // subdomínio: <slug>.mariachat.com.br
  name               String
  plano              String  @default("free") // "free" | "pro" | "enterprise"
  limiteConversasMes Int     @default(100)
  stripeCustomerId   String?
  waPhoneNumberId    String? @unique // número WhatsApp da org (roteia o webhook)
  waAccessToken      String?
  flows              Flow[]
  users              User[]
}

model Flow {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  nodes     Json     @default("[]") // array de FlowNode
  edges     Json     @default("[]") // array de FlowEdge
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id             String    @id @default(cuid())
  sessionId      String    @unique
  orgId          String    @default("dperj")
  channel        String // "whatsapp" | "web"
  flowId         String? // null = grafo estático
  status         String    @default("active") // "active" | "completed" | "abandoned"
  categoria      String?
  ultimaEtapa    String? // último node executado (análise de abandono)
  dadosColetados Json      @default("{}")
  protocoloDperj String?
  startedAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  completedAt    DateTime?

  @@index([orgId, startedAt])
}

model User {
  id     String @id @default(cuid())
  email  String @unique
  senha  String // hash bcrypt
  nome   String @default("")
  role   String @default("viewer") // "superadmin" | "admin" | "viewer"
  orgId  String
  org    Organization @relation(fields: [orgId], references: [id])
}
